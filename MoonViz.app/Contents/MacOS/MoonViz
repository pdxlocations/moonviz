#!/bin/zsh
APP_DIR="${0:A:h:h:h}"
cd "$APP_DIR" || exit 1

PORT=8123
URL="http://localhost:${PORT}/"

if ! /usr/bin/curl -fsI "$URL" >/dev/null 2>&1; then
  /usr/bin/python3 -m http.server "$PORT" --bind 127.0.0.1 >/tmp/moonviz-server.log 2>&1 &
  echo $! >/tmp/moonviz-server.pid

  for _ in {1..30}; do
    if /usr/bin/curl -fsI "$URL" >/dev/null 2>&1; then
      break
    fi
    sleep 0.1
  done
fi

/usr/bin/open "$URL"
